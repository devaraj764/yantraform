{
  "name": "yantraform",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "sudo env \"PATH=$PATH\" vite dev",
    "build": "vite build && node scripts/fix-knex-output.mjs",
    "start": "sudo env \"PATH=$PATH\" PORT=51821 HOST=0.0.0.0 node .output/server/index.mjs",
    "dev:no-sudo": "vite dev",
    "start:no-sudo": "node .output/server/index.mjs",
    "release": "sudo zip -qr yantraform.zip .output install.sh && gh release delete latest --yes 2>/dev/null; gh release create latest yantraform.zip --title \"Latest\" --notes \"Pre-built Yantraform dashboard. See README for install instructions.\"",
    "docker": "docker build -t ghcr.io/devaraj764/yantraform:latest . && docker push ghcr.io/devaraj764/yantraform:latest"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@tanstack/react-router": "^1.117.0",
    "@tanstack/react-start": "^1.117.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "lucide-react": "^0.468.0",
    "nitro": "npm:nitro-nightly@latest",
    "qrcode": "^1.5.4",
    "react": "19",
    "react-dom": "19",
    "react-hook-form": "^7.71.2",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
